{
  "name": "00_demo01",
  "module": "backend.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"cd frontend && bun run dev\" \"bun --watch backend.ts\"",
    "dev:backend": "bun --watch backend.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build:frontend": "cd frontend && bun run build",
    "build:backend": "bun build ./backend.ts --outdir ./dist",
    "build": "bun run build:frontend && bun run build:backend",
    "start": "bun dist/backend.js",
    "preview:frontend": "cd frontend && bun run preview"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "drizzle-orm": "^0.44.6",
    "elysia": "^1.4.28",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
