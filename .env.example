PORT=3000
# HOST：本機開發用 localhost；Render / 容器部署必須改為 0.0.0.0（否則只監聽本機，外部無法連線）
HOST=localhost
API_ALLOWED_ORIGIN=

# Store driver: "json" (default) | "postgres"
STORE_DRIVER=postgres

# Neon PostgreSQL connection strings
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_MIGRATION=postgresql://user:password@host/dbname?sslmode=require

# PostgreSQL schema namespace (avoid: public, breakfast, v8_legacy, drizzle)
# V8 使用 bf_v8，V9 使用 bf_v9（Expand-Contract：兩者並存，不互相覆蓋）
PG_SCHEMA=bf_v9

# ─── Better Auth ──────────────────────────────────────────────────────────────
# BETTER_AUTH_URL：後端的 base URL（開發用 http://localhost:3000）
# 部署時改為正式網址，OAuth callback 會依此組成
BETTER_AUTH_URL=http://localhost:3000

# BETTER_AUTH_SECRET：session 簽名金鑰，至少 32 bytes hex
# 產生方式：bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 必填，不設定 session 無法驗證；不要使用 'replaceme' 或空字串
BETTER_AUTH_SECRET=your-secret-here
